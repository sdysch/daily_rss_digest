# --- Required for sending to Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- LLM provider options (pick one) ---
# Option A: GitHub Models (free, works in GH Actions without extra keys)
# No env vars needed — uses GITHUB_TOKEN automatically

# Option B: OpenAI (or any OpenAI-compatible provider)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Option C: Groq (free tier)
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# --- Optional ---
# Comma-separated categories from your feeds file
# DIGEST_CATEGORIES=news,tech,python,arxiv,linux,misc,reddit
# FEEDS_URL=https://raw.githubusercontent.com/sdysch/dotfiles/refs/heads/master/setups/common/.config/newsboat/urls
# MAX_ARTICLES_PER_FEED=10
# DIGEST_COUNT=10
